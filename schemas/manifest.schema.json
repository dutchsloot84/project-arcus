{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-arcus.local/schemas/manifest.schema.json",
  "title": "Project Arcus Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "id",
    "name",
    "kind",
    "status",
    "owners",
    "artifacts"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "description": "Schema version for the manifest document.",
      "pattern": "^v?[0-9]+(\\.[0-9]+)*$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "description": "Stable identifier for the tracked artifact set or run."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "workflow",
        "adapter",
        "context",
        "example",
        "prompt-pack",
        "artifact-set",
        "run"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "archived", "superseded"]
    },
    "phase": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": ["input", "output", "reference", "template", "log", "report"]
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
